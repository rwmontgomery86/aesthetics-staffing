# ── Database ────────────────────────────────────────────────────────────────
# Service connection — full privileges, BYPASSES RLS. Used ONLY by the migration
# runner, seeds, background worker, matching engine, and webhook handlers.
# Local (Postgres.app):  postgresql://<mac-username>@localhost:5432/aesthetics_staffing
# Supabase:              the direct/session-pooler connection string (port 5432)
DATABASE_URL_SERVICE="postgresql://localhost:5432/aesthetics_staffing"

# RLS-enforced connection — the app's user-facing query path (dbAs helper).
# Connects as the `rls_client` role, which does NOT bypass RLS.
# Supabase: use the transaction-pooler host (port 6543) with the rls_client role.
DATABASE_URL_RLS="postgresql://rls_client:rls-client-dev@localhost:5432/aesthetics_staffing"

# Password assigned to the rls_client role by the bootstrap migration.
# Must match the password embedded in DATABASE_URL_RLS.
RLS_CLIENT_PASSWORD="rls-client-dev"

# ── Brand (working name is tentative — never hard-code it) ─────────────────
NEXT_PUBLIC_APP_NAME="OpenChair"
APP_BASE_URL="http://localhost:4000"
EMAIL_FROM="OpenChair <hello@example.test>"
SUPPORT_EMAIL="support@example.test"

# ── Integrations (all optional — console stubs when absent) ────────────────
# RESEND_API_KEY=""
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""
# MAPBOX_TOKEN=""
# SENTRY_DSN=""

# ── Supabase Auth (Phase 2+) ────────────────────────────────────────────────
# Project URL + anon (public) key from the Supabase dashboard → Settings → API.
# Leave unset to run the public site without auth (proxy passes through).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""   # not needed until storage signing (Phase 3)

NODE_ENV="development"
