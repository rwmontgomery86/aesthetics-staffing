{
  "name": "aesthetics-staffing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate && node scripts/post-generate-drizzle.mjs",
    "db:migrate": "tsx --conditions=react-server --env-file-if-exists=.env src/db/migrate.ts",
    "db:seed": "tsx --conditions=react-server --env-file-if-exists=.env src/db/seed/index.ts",
    "db:seed:demo": "tsx --conditions=react-server --env-file-if-exists=.env src/db/seed/demo.ts",
    "geo:load": "tsx --conditions=react-server --env-file-if-exists=.env scripts/load-geo.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "drizzle-orm": "0.36.4",
    "next": "16.2.6",
    "pg": "8.13.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "server-only": "^0.0.1",
    "tsx": "4.19.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "0.5.7",
    "@types/node": "22.9.3",
    "@types/pg": "8.11.10",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "adm-zip": "0.5.16",
    "drizzle-kit": "0.28.1",
    "eslint": "9.15.0",
    "shapefile": "0.6.6",
    "typescript": "5.6.3",
    "typescript-eslint": "8.15.0",
    "vitest": "2.1.5"
  }
}
