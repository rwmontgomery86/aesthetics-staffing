{
  "name": "aesthetics-staffing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate && node scripts/post-generate-drizzle.mjs",
    "db:migrate": "tsx --conditions=react-server --env-file-if-exists=.env src/db/migrate.ts",
    "db:seed": "tsx --conditions=react-server --env-file-if-exists=.env src/db/seed/index.ts",
    "db:seed:demo": "tsx --conditions=react-server --env-file-if-exists=.env src/db/seed/demo.ts",
    "geo:load": "tsx --conditions=react-server --env-file-if-exists=.env scripts/load-geo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "tsx --conditions=react-server --env-file-if-exists=.env src/workers/index.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "drizzle-orm": "0.36.4",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "luxon": "^3.7.2",
    "next": "16.2.6",
    "pg": "8.13.1",
    "pg-boss": "^10.4.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "^4.2.1",
    "server-only": "^0.0.1",
    "tsx": "4.19.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "0.5.7",
    "@types/leaflet": "^1.9.14",
    "@types/leaflet-draw": "^1.0.11",
    "@types/luxon": "^3.7.1",
    "@types/node": "22.9.3",
    "@types/pg": "8.11.10",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "adm-zip": "0.5.16",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "0.28.1",
    "eslint": "9.15.0",
    "postcss": "^8.4.49",
    "shapefile": "0.6.6",
    "tailwindcss": "^3.4.15",
    "typescript": "5.6.3",
    "typescript-eslint": "8.15.0",
    "vitest": "2.1.5"
  }
}
